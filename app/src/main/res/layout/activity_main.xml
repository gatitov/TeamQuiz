<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_mesh_bg"
    tools:context=".MainActivity">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#A78BFA"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:strokeColor="@android:color/transparent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🧠"
                android:textSize="22sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="@string/app_name"
            android:textColor="#3D1E6D"
            android:textSize="20sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#CCFFFFFF"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:strokeColor="@android:color/transparent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="11dp"
                android:src="@drawable/ic_settings_gear"
                app:tint="#7C3AED" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/headline_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/top_bar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/ready_to_test"
            android:textColor="#1E1B4B"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/txt_question_mark_gradient"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/knowledge"
            android:textColor="#8B5CF6"
            android:textSize="44sp" />
    </LinearLayout>

    <!-- Illustration Card -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/illustration_card"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="110dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/glass_card_bg"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintBottom_toTopOf="@+id/label_categories"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headline_container">

        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/q_mark_glow"
            android:alpha="0.22"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Main Question Mark -->
        <TextView
            android:id="@+id/txt_question_mark_shadow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textColor="#3B0764"
            android:alpha="0.28"
            android:textSize="86sp"
            android:fontFamily="sans-serif-black"
            android:translationX="4dp"
            android:translationY="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/txt_question_mark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textColor="#8B5CF6"
            android:textSize="86sp"
            android:fontFamily="sans-serif-black"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Decor Elements -->
        <View
            android:id="@+id/decor_stick_left"
            android:layout_width="14dp"
            android:layout_height="3dp"
            android:background="@drawable/shape_rounded_line"
            android:backgroundTint="#C4B5FD"
            android:alpha="0.6"
            android:rotation="-35"
            app:layout_constraintBottom_toTopOf="@+id/txt_question_mark"
            app:layout_constraintEnd_toStartOf="@+id/txt_question_mark"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="-5dp" />

        <View
            android:id="@+id/decor_stick_right_1"
            android:layout_width="12dp"
            android:layout_height="3dp"
            android:background="@drawable/shape_rounded_line"
            android:backgroundTint="#C4B5FD"
            android:alpha="0.6"
            android:rotation="30"
            app:layout_constraintTop_toTopOf="@+id/txt_question_mark"
            app:layout_constraintStart_toEndOf="@+id/txt_question_mark"
            android:layout_marginStart="20dp"
            android:layout_marginTop="15dp" />

        <View
            android:id="@+id/decor_stick_right_2"
            android:layout_width="12dp"
            android:layout_height="3dp"
            android:background="@drawable/shape_rounded_line"
            android:backgroundTint="#EC4899"
            android:alpha="0.7"
            android:rotation="-15"
            app:layout_constraintTop_toTopOf="@+id/txt_question_mark"
            app:layout_constraintStart_toEndOf="@+id/txt_question_mark"
            android:layout_marginStart="25dp"
            android:layout_marginTop="35dp" />

        <TextView
            android:id="@+id/decor_diamond"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textColor="#06B6D4"
            android:textSize="14sp"
            android:alpha="0.6"
            app:layout_constraintEnd_toStartOf="@+id/txt_question_mark"
            app:layout_constraintBottom_toBottomOf="@+id/txt_question_mark"
            android:layout_marginEnd="22dp"
            android:layout_marginBottom="15dp"/>

        <TextView
            android:id="@+id/decor_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="★"
            android:textColor="#FBBF24"
            android:textSize="14sp"
            android:alpha="0.7"
            app:layout_constraintStart_toEndOf="@+id/txt_question_mark"
            app:layout_constraintBottom_toBottomOf="@+id/txt_question_mark"
            android:layout_marginStart="25dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/decor_qmark_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textColor="#8B5CF6"
            android:textSize="18sp"
            android:alpha="0.8"
            android:textStyle="bold"
            android:rotation="-15"
            app:layout_constraintBottom_toTopOf="@+id/txt_question_mark"
            app:layout_constraintEnd_toStartOf="@+id/txt_question_mark"
            android:layout_marginEnd="-8dp"
            android:layout_marginBottom="-12dp"/>

        <TextView
            android:id="@+id/decor_qmark_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textColor="#EC4899"
            android:textSize="16sp"
            android:alpha="0.8"
            android:textStyle="bold"
            android:rotation="15"
            app:layout_constraintBottom_toTopOf="@+id/txt_question_mark"
            app:layout_constraintStart_toEndOf="@+id/txt_question_mark"
            android:layout_marginStart="-5dp"
            android:layout_marginBottom="-8dp"/>

        <TextView
            android:id="@+id/decor_qmark_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="?"
            android:textColor="#06B6D4"
            android:textSize="14sp"
            android:alpha="0.7"
            android:textStyle="bold"
            android:rotation="-10"
            app:layout_constraintTop_toBottomOf="@+id/txt_question_mark"
            app:layout_constraintEnd_toStartOf="@+id/txt_question_mark"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="-28dp"/>

        <!-- Circles -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/yellow_circle_base"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:alpha="0.6"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:strokeColor="@android:color/transparent"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_yellow_blob" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚡"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/target_circle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="18dp"
            android:alpha="0.6"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:strokeColor="@android:color/transparent"
            app:cardBackgroundColor="@android:color/transparent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/shape_purple_blob" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🎯"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Categories Row -->
    <TextView
        android:id="@+id/label_categories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="12dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/categories"
        android:textColor="#1E1B4B"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/categories_container"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/btn_see_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:text="@string/see_all"
        android:textColor="#8B5CF6"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/label_categories"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/categories_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btn_start_quiz_wrapper">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="84dp"
                app:cardBackgroundColor="#E0F2FE"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔬" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/science" android:textSize="11sp" android:textStyle="bold" android:textColor="#374151"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="84dp"
                app:cardBackgroundColor="#FCE7F3"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📚" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/history" android:textSize="11sp" android:textStyle="bold" android:textColor="#374151"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="84dp"
                app:cardBackgroundColor="#DCFCE7"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌍" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/geography" android:textSize="11sp" android:textStyle="bold" android:textColor="#374151"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="72dp"
                android:layout_height="84dp"
                app:cardBackgroundColor="#FEF3C7"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎨" android:textSize="22sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/arts" android:textSize="11sp" android:textStyle="bold" android:textColor="#374151"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_start_quiz_wrapper"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:strokeColor="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/btn_start_gradient">

            <View
                android:id="@+id/shimmer_view"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:background="@drawable/shimmer_shine"
                android:translationX="-100dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/btn_start_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/start_quiz"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>